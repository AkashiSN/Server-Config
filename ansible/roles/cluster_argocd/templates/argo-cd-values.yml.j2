global:
 domain: "{{ argocd_fqdn }}"
configs:
  cm:
    create: true
    url: "https://{{ argocd_fqdn }}"
    admin.enabled: false
    exec.enabled: true
    statusbadge.enabled: true
    dex.config: |-
      connectors:
        - type: oidc
          id: oidc
          name: cloudflare
          config:
            issuer: "{{ argocd_oidc_issuer }}"
            clientID: "{{ argocd_oidc_client_id }}"
            clientSecret: "{{ argocd_oidc_client_secret }}"
            insecureSkipEmailVerified: true
            getUserInfo: true
            requestedScopes:
              - openid
              - profile
              - email
              - groups
  params:
    server.insecure: true
  rbac:
    policy.default: "role:admin"
    scopes: "[email]"
  secret:
    githubSecret: "{{ argocd_webhook_github_secret }}"
dex:
  enabled: true
server:
  # argo-cd namespace の Gateway `argo-cd` (cluster_argocd role が apply 済み) の
  # https listener に attach する HTTPRoute を chart 側で生成する。Gateway API CRD は
  # cluster_gateway_api で先に install 済み。
  httproute:
    enabled: true
    parentRefs:
      - name: argo-cd
        sectionName: https
    hostnames:
      - "{{ argocd_fqdn }}"
